{
    "name": "node-template",
    "version": "1.0.0",
    "description": "base setup for nodejs projects",
    "repository": {
        "type": "git",
        "url": "git@github.com-adityatarale:AdityaTarale/node-template.git"
    },
    "license": "ISC",
    "author": "Aditya Tarale <tarale.adi@gmail.com>",
    "type": "module",
    "main": "index.js",
    "scripts": {
        "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand",
        "test:watch": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --watch --runInBand",
        "dev": "tsx watch src/server.ts",
        "build": "tsc -p tsconfig.build.json",
        "format:fix": "prettier . --write",
        "format:check": "prettier . --check",
        "lint:fix": "eslint . --fix",
        "lint:check": "eslint .",
        "prepare": "husky"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/express": "^5.0.6",
        "@types/http-errors": "^2.0.5",
        "@types/jest": "^30.0.0",
        "@types/node": "^25.6.0",
        "@types/supertest": "^7.2.0",
        "@types/winston": "^2.4.4",
        "eslint": "^10.2.1",
        "globals": "^17.5.0",
        "husky": "^9.1.7",
        "jest": "^30.3.0",
        "lint-staged": "^16.4.0",
        "prettier": "3.8.3",
        "ts-jest": "^29.4.9",
        "tsx": "^4.21.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.1"
    },
    "lint-staged": {
        "*.ts": [
            "npm run format:fix",
            "npm run lint:fix"
        ]
    },
    "dependencies": {
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "http-errors": "^2.0.1",
        "supertest": "^7.2.2",
        "winston": "^3.19.0"
    }
}
